{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext"],
    "moduleResolution": "node",

    "strict": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    
    "composite": true,
    "noEmitOnError": true,

    "rootDir": "./",
    "outDir": ".build"
  }
}
